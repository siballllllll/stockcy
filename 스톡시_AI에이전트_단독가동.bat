@echo off
title 🤖 스톡시 AI 자율 매매 에이전트 (단독 가동 모드)
chcp 65001 >nul
set "SCRIPT_DIR=%~dp0"
cd /d "%SCRIPT_DIR%"

echo ====================================================
echo      스톡시 AI 자율 매매 에이전트 단독 기동 (서버 미기동)
echo ====================================================
echo [*] 가상환경 활성화 및 인코딩 세팅 확인 중...

if not exist "venv\Scripts\python.exe" (
    echo [오류] 가상환경(venv)을 찾을 수 없습니다. venv 폴더를 확인해 주세요.
    pause
    exit /b
)

echo [*] AI 자율 트레이딩 에이전트를 백그라운드 서버 없이 직접 실행합니다.
echo [*] 중단하려면 콘솔창에서 [Ctrl + C]를 누르십시오.
echo ====================================================
echo.

.\venv\Scripts\python.exe -X utf8 api/agent.py

echo.
echo ====================================================
echo [알림] 에이전트 실행이 종료되었습니다.
echo ====================================================
pause
