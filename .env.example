# ================================================================
# Stockcy FastAPI 서버 환경변수 설정
# 이 파일을 복사하여 .env 로 저장한 뒤 실제 값을 입력하세요.
# ================================================================

# ── Gemini AI ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── KIS Open API (한국투자증권) ────────────────────────────────
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here

# ── Google Sheets (서비스 계정 JSON을 한 줄 문자열로) ───────────
# secrets.toml 의 [gspread.credentials] 섹션을 JSON 문자열로 변환
# 예: {"type":"service_account","project_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\\n..."}
GSPREAD_CREDENTIALS={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"KEY_ID","private_key":"-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY\n-----END RSA PRIVATE KEY-----\n","client_email":"YOUR@EMAIL.iam.gserviceaccount.com","client_id":"CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
GSPREAD_SPREADSHEET_ID=your_spreadsheet_id_here

# ── Telegram Bot ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── 서버 설정 ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── 인증 (멀티유저) ────────────────────────────────────────────
# 세션 토큰 서명용 비밀키. 비워두면 DB에 자동 생성·영속된다(서버 이전 시엔 직접 지정 권장).
AUTH_SECRET=
# 최초 1회 관리자 계정 시드. ADMIN_PASSWORD 를 비우면 임의 생성되어 backend.log 에 1회 출력된다.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
